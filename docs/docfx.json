{
  "metadata": [
    {
      "src": [
        {
          "files": ["**/*.csproj"],
          "exclude": ["**/bin/**", "**/obj/**"],
          "src": "../src"
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["*.md"],
        "exclude": ["_site/**"]
      }
    ],
    "globalMetadata": {
      "_appTitle": "Conduit",
      "_appFooter": "Conduit - A .NET data pipeline for multi-source data processing",
      "_enableSearch": true,
      "_appLogoPath": "",
      "_appFaviconPath": ""
    },
    "dest": "_site"
  },
  "pdf": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["*.md"],
        "exclude": ["_site/**"]
      }
    ],
    "globalMetadata": {
      "_appTitle": "Conduit API Reference"
    },
    "dest": "_site/pdf"
  }
}
